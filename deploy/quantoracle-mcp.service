[Unit]
Description=QuantOracle MCP Server
After=network.target quantoracle.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/quantoracle/mcp-server
ExecStart=/usr/bin/node dist/index.js
Restart=always
RestartSec=5
Environment=BACKEND_URL=http://localhost:8001
Environment=PORT=8002

[Install]
WantedBy=multi-user.target
