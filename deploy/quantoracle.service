[Unit]
Description=QuantOracle API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/quantoracle
ExecStart=/usr/local/bin/gunicorn quantoracle:app -w 4 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:8001
Restart=always
RestartSec=5
Environment=QO_API_KEYS=

[Install]
WantedBy=multi-user.target
