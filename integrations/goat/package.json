{
  "name": "@quantoracle/goat-plugin",
  "version": "0.1.0",
  "description": "Deterministic quant finance plugin for the GOAT SDK (Crossmint's onchain agent toolkit) — Black-Scholes, Kelly, Monte Carlo, full risk audit, hedge recommender, options, risk, DeFi tools. 15 tools across 4 opt-in bundles. Multi-chain (EVM + Solana) via x402.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "goat-sdk",
    "goat-plugin",
    "crossmint",
    "onchain-agent",
    "ai-agent",
    "quant-finance",
    "options-pricing",
    "black-scholes",
    "kelly-criterion",
    "monte-carlo",
    "solana",
    "evm",
    "base",
    "x402"
  ],
  "author": "QuantOracle <hello@quantoracle.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/QuantOracledev/quantoracle.git",
    "directory": "integrations/goat"
  },
  "homepage": "https://quantoracle.dev",
  "peerDependencies": {
    "@goat-sdk/core": ">=0.3.0 <1.0.0",
    "zod": ">=3.22.0 <4.0.0"
  },
  "devDependencies": {
    "@goat-sdk/core": "^0.4.0",
    "@swc/core": "^1.4.0",
    "@types/node": "^20.0.0",
    "reflect-metadata": "^0.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "zod": "^3.23.0"
  }
}
