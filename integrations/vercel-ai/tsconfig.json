{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./dist",
    "lib": ["ES2022", "DOM"]
  },
  "include": ["index.ts", "tools.ts", "schemas.ts", "constants.ts"],
  "exclude": ["node_modules", "dist", "example-agent.ts"]
}
